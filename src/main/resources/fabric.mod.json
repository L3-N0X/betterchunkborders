{
	"schemaVersion": 1,
	"id": "betterchunkborders",
	"version": "${version}",
	"name": "Better Chunk Borders",
	"description": "Improves the visual appearance of chunk borders.",
	"authors": [
		"L3-N0X"
	],
	"contact": {
		"sources": "https://github.com/L3-N0X/betterchunkborders"
	},
	"license": "MIT",
	"icon": "assets/betterchunkborders/icon.png",
	"environment": "*",
	"entrypoints": {
		"modmenu": [
			{
				"value": "de.lenox.client.compat.ModMenuIntegration",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		{
			"config": "betterchunkborders.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"yet_another_config_lib_v3": ">=3.9.4",
		"modmenu": "*"
	}
}